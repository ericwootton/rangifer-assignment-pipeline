/*
========================================================================================
    RANGIFER ASSIGNMENT PIPELINE - Nextflow Configuration
========================================================================================
*/

params {
    // Input
    wgs_vcf              = null
    genotype_matrix      = null   // Pre-QC'd genotype matrix TSV (herd_diff mode)
    metadata             = null
    finalreport          = null
    fr_samplesheet       = null
    nwt_genotypes        = null
    faulty_probes        = null
    chip_manifest        = null
    fasta                = null
    outdir               = 'results'

    // Mode: 'snp' (default), 'mito', 'wgs', or 'herd_diff'
    mode                 = 'snp'

    // WGS mode inputs
    bam_dir              = null

    // Container directory (path to directory containing .sif files)
    container_dir        = null

    // Sample QC thresholds
    min_call_rate        = 0.70
    max_het              = 0.50
    min_het              = 0.15
    snp_call_rate        = 0.70
    max_snp_het          = 0.49
    ibs_threshold        = 0.95
    skip_strand_filter   = false   // set true for single-platform (WGS-only/mito) runs

    // Classification minimum sample sizes per class
    min_samples_dapc      = 5
    min_samples_assignpop = 5
    min_samples_popfinder = 5

    // Structure discovery
    max_k_structure      = 15
    max_k_dapc           = 20

    // Platform batch correction
    batch_alpha          = 0.01

    // Node-level SNP QC
    node_snp_call_rate   = 0.80

    // Resource limits
    max_cpus             = 16
    max_memory           = '64.GB'
    max_time             = '72.h'

    help                 = false
}

// Container paths
def container_base = params.container_dir ?: "${projectDir}/containers"
params.containers = [
    bcftools:           "${container_base}/bcftools.sif",
    plink:              "${container_base}/plink.sif",
    plink2:             "${container_base}/plink2.sif",
    r_popgen:           "${container_base}/r-popgen-dt.sif",
    r_popgen_outflank:  "${container_base}/r-popgen-outflank.sif",
    popfinder:          "${container_base}/popfinder.sif",
    admixture:          "${container_base}/admixture.sif",
    python:             "${container_base}/python-scientific.sif",
    delly:              "${container_base}/delly.sif",
    eagle:              "${container_base}/eagle.sif",
    pixy:               "${container_base}/pixy.sif",
    ibdseq:             "${container_base}/ibdseq.sif",
    finestructure:      "${container_base}/finestructure.sif"
]

process {
    errorStrategy = { task.exitStatus in [143,137,104,134,139,140,255,135,1] ? 'retry' : 'finish' }
    maxRetries = 3

    // Default: minimal resources
    cpus   = { check_max( 1 * task.attempt, 'cpus' ) }
    memory = { check_max( 1.GB * task.attempt, 'memory' ) }
    time   = { check_max( 30.min * task.attempt, 'time' ) }

    withLabel: process_low {
        cpus   = { check_max( 2 * task.attempt, 'cpus' ) }
        memory = { check_max( 2.GB * task.attempt, 'memory' ) }
        time   = { check_max( 30.min * task.attempt, 'time' ) }
    }

    withLabel: process_medium {
        cpus   = { check_max( 4 * task.attempt, 'cpus' ) }
        memory = { check_max( 4.GB * task.attempt, 'memory' ) }
        time   = { check_max( 1.h * task.attempt, 'time' ) }
    }

    withLabel: process_high {
        cpus   = { check_max( 4 * task.attempt, 'cpus' ) }
        memory = { check_max( 8.GB * task.attempt, 'memory' ) }
        time   = { check_max( 2.h * task.attempt, 'time' ) }
    }

    // ============================
    // Phase 1: Data Integration
    // ============================
    withName: 'CONVERT_FINALREPORT' {
        container = params.containers.r_popgen
        label = 'process_low'
    }
    withName: 'CONVERT_NWT_GENOTYPES' {
        container = params.containers.r_popgen
    }
    withName: 'EXTRACT_VCF_GENOTYPES' {
        container = params.containers.bcftools
    }
    withName: 'MERGE_GENOTYPE_SOURCES' {
        container = params.containers.r_popgen
        label = 'process_low'
    }

    // ============================
    // Phase 2: QC
    // ============================
    withName: 'SAMPLE_QC' {
        container = params.containers.r_popgen
    }
    withName: 'SNP_QC' {
        container = params.containers.r_popgen
    }
    withName: 'DUPLICATE_DETECTION' {
        container = params.containers.r_popgen
    }
    withName: 'BATCH_CORRECT' {
        container = params.containers.r_popgen
        label = 'process_low'
    }

    // ============================
    // Phase 3: Structure Discovery
    // ============================
    withName: 'RUN_PCA' {
        container = params.containers.r_popgen
        label = 'process_low'
    }
    withName: 'DAPC_FIND_CLUSTERS' {
        container = params.containers.r_popgen
        label = 'process_low'
    }
    withName: 'CONVERT_TO_BED' {
        container = params.containers.plink
    }
    withName: 'RUN_ADMIXTURE' {
        container = params.containers.admixture
        label = 'process_medium'
        time = { check_max( 3.h * task.attempt, 'time' ) }
    }
    withName: 'SYNTHESIZE_STRUCTURE' {
        container = params.containers.r_popgen
    }

    // ============================
    // Phase 4: Classification (shared)
    // ============================
    withName: 'PREPARE_NODE_DATA' {
        container = params.containers.r_popgen
    }
    withName: 'CONVERT_NODE_BED' {
        container = params.containers.plink
    }
    withName: 'RUN_NODE_ADMIXTURE' {
        container = params.containers.admixture
        label = 'process_medium'
    }
    withName: 'RUN_DAPC' {
        container = params.containers.r_popgen
        label = 'process_high'
    }
    withName: 'RUN_ASSIGNPOP' {
        container = params.containers.r_popgen
        label = 'process_high'
        time = { check_max( 2.h * task.attempt, 'time' ) }
    }
    withName: 'RUN_POPFINDER' {
        container = params.containers.popfinder
        cpus   = { check_max( 16 * task.attempt, 'cpus' ) }
        memory = { check_max( 4.GB * task.attempt, 'memory' ) }
        time   = { check_max( 30.min * task.attempt, 'time' ) }
    }
    withName: 'ENSEMBLE_DECISION' {
        container = params.containers.r_popgen
    }
    withName: 'GENERATE_NODE_PLOTS' {
        container = params.containers.r_popgen
        label = 'process_medium'
    }

    // ============================
    // Herd differentiation mode
    // ============================
    withName: 'PREPARE_HERD_DATA' {
        container = params.containers.r_popgen
        label = 'process_medium'
    }
    withName: 'PAIRWISE_FST' {
        container = params.containers.r_popgen
        label = 'process_high'
    }
    withName: 'HERD_DIFF_SUMMARY' {
        container = params.containers.r_popgen
    }

    // ============================
    // SNP mode: Fst node filter
    // ============================
    withName: 'FST_NODE_FILTER' {
        container = params.containers.r_popgen
        label = 'process_medium'
    }

    // ============================
    // WGS mode: SV calling (Delly)
    // ============================
    withName: 'CALL_SVS_DISCOVER' {
        container = params.containers.delly
        label = 'process_medium'
        time = { check_max( 4.h * task.attempt, 'time' ) }
    }
    withName: 'MERGE_SV_SITES' {
        container = params.containers.delly
        label = 'process_medium'
    }
    withName: 'GENOTYPE_SVS' {
        container = params.containers.delly
        label = 'process_medium'
        time = { check_max( 4.h * task.attempt, 'time' ) }
    }
    withName: 'MERGE_SV_GENOTYPES' {
        container = params.containers.bcftools
        label = 'process_medium'
    }

    // ============================
    // WGS mode: Phasing (Eagle)
    // ============================
    withName: 'PHASE_VCF' {
        container = params.containers.eagle
        label = 'process_high'
        time = { check_max( 12.h * task.attempt, 'time' ) }
    }

    // ============================
    // WGS mode: Per-node analyses
    // ============================
    withName: 'COMPUTE_FST_DXY' {
        container = params.containers.pixy
        label = 'process_medium'
    }
    withName: 'OUTFLANK_OUTLIERS' {
        container = params.containers.r_popgen_outflank
        label = 'process_medium'
    }
    withName: 'PREPARE_WGS_NODE_DATA' {
        container = params.containers.r_popgen
    }
    withName: 'IBD_NETWORK' {
        container = params.containers.ibdseq
        label = 'process_medium'
        time = { check_max( 4.h * task.attempt, 'time' ) }
    }
    withName: 'CHROMOPAINTER_FINESTRUCTURE' {
        container = params.containers.finestructure
        label = 'process_high'
        time = { check_max( 12.h * task.attempt, 'time' ) }
    }

    // ============================
    // Phase 5: Output
    // ============================
    withName: 'COMPILE_ASSIGNMENTS' {
        container = params.containers.r_popgen
    }
    withName: 'FEATURE_IMPORTANCE' {
        container = params.containers.r_popgen
    }
    withName: 'GENERATE_REPORT' {
        container = params.containers.r_popgen
        label = 'process_low'
    }
}

profiles {
    debug {
        process.beforeScript = 'echo $HOSTNAME'
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        podman.enabled         = false
    }

    rorqual {
        process.executor       = 'slurm'
        process.clusterOptions = { "--account=${System.getenv('SLURM_ACCOUNT') ?: 'def-mygroup'}" }

        singularity.enabled    = true
        singularity.autoMounts = true
        singularity.runOptions = '-B /project -B /scratch --env PYTHONNOUSERSITE=1 --env PYTHONDONTWRITEBYTECODE=1 --env HOME=/tmp'

        params.max_cpus        = 192
        params.max_memory      = '750.GB'
        params.max_time        = '168.h'

        executor {
            queueSize          = 20
            submitRateLimit    = '10/1min'
            pollInterval       = '30 sec'
            queueStatInterval  = '1 min'
            jobName            = { "RA_${task.process.split(':')[-1]}_${task.index}" }
        }
    }

    test {
        params.max_cpus   = 2
        params.max_memory = '8.GB'
        params.max_time   = '1.h'
    }
}

manifest {
    name            = 'rangifer-assignment-pipeline'
    author          = 'E. Wootton'
    description     = 'Hierarchical ensemble classification of Rangifer tarandus samples'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.04.0'
    version         = '2.0.0'
}

def timestamp = new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_timeline_${timestamp}.html"
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_report_${timestamp}.html"
}
trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_trace_${timestamp}.txt"
    fields  = 'task_id,hash,native_id,process,tag,name,status,exit,submit,duration,realtime,cpus,memory,%cpu,%mem,rss,vmem'
}
dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/pipeline_dag_${timestamp}.svg"
}

def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) {
            println "ERROR: Invalid memory specification: ${obj}"
            System.exit(1)
        }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else
                return obj
        } catch (all) {
            println "ERROR: Invalid time specification: ${obj}"
            System.exit(1)
        }
    } else if (type == 'cpus') {
        try {
            return Math.min( obj, params.max_cpus as int )
        } catch (all) {
            println "ERROR: Invalid cpu specification: ${obj}"
            System.exit(1)
        }
    }
}
